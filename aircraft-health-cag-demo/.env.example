# Copy to .env and fill in your key (get one at https://console.anthropic.com/).
# Leaving this empty is valid; the UI will show setup errors until you set a real key.
ANTHROPIC_API_KEY=sk-ant-...

# Optional — defaults below match the local mock server (no need to uncomment for local dev)
# CDF_BASE_URL=http://localhost:4001
# CDF_TOKEN=mock-token
# CDF_PROJECT=desert_sky

# Optional — pin the demo's "today" date for reproducible dataset generation
# DESERT_SKY_DEMO_DATE=YYYY-MM-DD
